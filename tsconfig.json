{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  // "scripts" (verify.ts / verify_scoring.ts) is intentionally NOT included
  // here. Those files use Node globals (process.exit) and are run directly
  // via `tsx` (see package.json's "verify" script), which transpiles them
  // without needing them to satisfy this project's browser-focused tsconfig.
  // Including them here made `tsc -b` (part of `npm run build`) fail on
  // Netlify with "Cannot find name 'process'" — tsx never hit that because
  // it doesn't type-check against this file.
  "references": [{ "path": "./tsconfig.node.json" }]
}
